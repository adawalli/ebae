# Copy to .env.local (next dev) or pass as container env.

# Postgres - Neon, local, anything. Required.
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# eBay app credentials (developer.ebay.com). Leave unset to run in mock mode:
# the poller generates fake listings so the whole pipeline works without a token.
#EBAY_CLIENT_ID=
#EBAY_CLIENT_SECRET=
#EBAY_ENV=production        # or: sandbox
#EBAY_MARKETPLACE=EBAY_US

# Discord webhook to notify (channels table rows work too)
#DISCORD_WEBHOOK_URL=

#POLL_INTERVAL_DEFAULT=5    # minutes, when a search doesn't specify
#CACHE_REFRESH_HOURS=12     # DB -> cache refresh cadence
#EBAY_DAILY_QUOTA=5000      # enforced daily call budget

#LOG_LEVEL=info             # error | warn | info | debug (debug shows every eBay/discord call)
#LOG_FORMAT=json            # json | pretty (defaults to pretty on a TTY, json otherwise)
