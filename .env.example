# Copy to .env.local (next dev) or pass as container env.

# Postgres - Neon, local, anything. Required.
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# eBay app credentials (developer.ebay.com). Leave unset to run in mock mode:
# the poller generates fake listings so the whole pipeline works without a token.
# Single mode only - in a multi-user mode each user enters their own keys in the UI.
#EBAY_CLIENT_ID=
#EBAY_CLIENT_SECRET=
#EBAY_ENV=production        # or: sandbox
#EBAY_MARKETPLACE=EBAY_US

# Discord webhook to notify (more targets can be added in the UI).
# Single mode only - one global webhook would fan every user's alerts into one channel.
#DISCORD_WEBHOOK_URL=

# Web Push. Nothing here is required: the keypair is generated on first use and stored in
# the database, so push works with no setup. Set both keys to pin them instead (generate:
# npx web-push generate-vapid-keys). Changing the keypair invalidates every existing
# subscription - each device has to opt in again.
#VAPID_PUBLIC_KEY=
#VAPID_PRIVATE_KEY=

# Contact URI the push services see, so they can reach you about a misbehaving sender.
# Must be a mailto: or https: URI. It must NOT point at localhost: Apple rejects those
# with 403 BadJwtToken, which silently breaks push on every iPhone while Chrome keeps
# working. Defaults to this project's repo, which is valid everywhere.
#VAPID_SUBJECT=mailto:you@example.com

# Auth. Default is single: no login, one implicit user, today's trust model (localhost,
# LAN, your own proxy). Everything below is optional and only needed to share one
# deployment with other people - see the README's Multi-user section.
#AUTH_MODE=single           # single | cloudflare | proxy

# cloudflare: validates Access's signed JWT. Both required in that mode (boot fails otherwise).
#CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
#CF_ACCESS_AUD=            # Access application's Audience (AUD) tag

# proxy: trust this header's value as the user's email. ONLY when the app is reachable
# exclusively through your SSO proxy - the header is spoofable by anyone who can reach
# the app directly. Required in that mode.
#AUTH_TRUSTED_HEADER=Remote-Email

# Encrypts eBay client secrets saved through the UI. Generate: openssl rand -base64 32
# Not needed in single mode (env creds are never stored). No key history: lose it and
# each user re-enters their eBay keys.
#ENCRYPTION_KEY=

# One-time, only when switching an existing single-user DB to a multi-user mode: assigns
# every pre-existing search/channel/alert to this user at boot. Remove afterwards.
#LEGACY_OWNER_EMAIL=

#POLL_INTERVAL_DEFAULT=5    # minutes, when a search doesn't specify
#CACHE_REFRESH_HOURS=12     # DB -> cache refresh cadence
#EBAY_DAILY_QUOTA=5000      # enforced daily call budget, per user (each brings their own eBay app)
#SEEN_RETENTION_DAYS=90     # days to keep seen_items dedupe rows

# Overnight snooze (pause polling while you sleep) is configured in the UI on the
# Status page, not here - it's stored in the database.

#LOG_LEVEL=info             # error | warn | info | debug (debug shows every eBay/discord call)
#LOG_FORMAT=json            # json | pretty (defaults to pretty on a TTY, json otherwise)
